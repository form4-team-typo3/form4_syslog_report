{
  "name": "form4/form4-syslog-report",
  "type": "typo3-cms-extension",
  "description": "TYPO3 extension to send email reports of system log entries via console command or scheduler task",
  "minimum-stability": "stable",
  "version": "12.4.2",
  "require": {
    "php": "^8.1",
    "typo3/cms-core": "~12.4.0"
  },
  "autoload": {
    "psr-4": {
      "FORM4\\Form4SyslogReport\\": "Classes"
    }
  },
  "extra": {
    "typo3/cms": {
      "extension-key": "form4_syslog_report"
    }
  }
}
